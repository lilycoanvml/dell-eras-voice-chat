    { "step": 5, "element": "era_description", "duration": 500, "delay": 1100, "easing": "ease-out" },
    { "step": 6, "element": "products_header", "duration": 400, "delay": 2200, "easing": "ease-out" },
    { "step": 7, "element": "product_card_1", "duration": 500, "delay": 2350, "easing": "ease-out" },
    { "step": 8, "element": "product_card_2", "duration": 500, "delay": 2500, "easing": "ease-out" },
    { "step": 9, "element": "product_card_3", "duration": 500, "delay": 2650, "easing": "ease-out" }
